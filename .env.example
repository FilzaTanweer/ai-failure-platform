# System Operational Boundaries
APP_ENV=development
APP_NAME="AI Project Failure Intelligence Platform"
DEBUG=true
PORT=8000

# Security Infrastructure 
# Generate a production key securely using: openssl rand -hex 32
SECRET_KEY=dev_fallback_secure_hash_string_32_chars_minimum_len

# Database Persistence Token Core
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_failure_db